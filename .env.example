# Copy this file to `.env` and edit anything you want to override.
# Anything left commented uses the default baked into docker-compose.yml.

# --- Postgres (used only by the isolated `db` container) ---
POSTGRES_USER=bugtracker
POSTGRES_PASSWORD=bugtracker_pw
POSTGRES_DB=bugtracker

# --- App ---
APP_NAME=Bug Hunter
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# Public base URL — used in the "View" links inside notification emails.
# Change this to your VM/server URL when you deploy.
APP_BASE_URL=http://10.1.131.199:8765

# Comma-separated list of allowed origins, or * for any.
CORS_ORIGINS=*

# Optional shared secret. If set, every write request (POST/PUT/DELETE)
# must include header  X-API-Key: <value>.  Leave blank to disable.
API_KEY=

# --- Authentication ---
# Required in production. Generate with:  openssl rand -hex 32
# If left blank, a random per-process secret is used — every restart
# invalidates every active session, fine for dev only.
SESSION_SECRET=

# Session lifetime in seconds. Default: 86400 (1 day).
SESSION_TTL_SECONDS=86400

# Set to true when serving over HTTPS so the session cookie is only sent
# on TLS connections. Leave false for plain-HTTP internal deployments.
COOKIE_SECURE=false

# First-time bootstrap admin. Used only when the database has zero users —
# i.e., on first run, or after wiping the volume. After your first login,
# change the password from the Account panel and never use these defaults
# in production.
BOOTSTRAP_ADMIN_EMAIL=admin@bughunter.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_NAME=Admin

# Override only if you also want to run the app outside Docker against
# the dockerised Postgres. Inside the compose network the app uses
# `db:5432`; from the host you'd use `localhost:55432`.
# DATABASE_URL=postgresql+psycopg://bugtracker:bugtracker_pw@localhost:55432/bugtracker

# --- Email notifications ---
# Backends:
#   console   (default) Logs every email to stdout. Perfect for dev/testing.
#   smtp      Sends real email via the SMTP_* settings below.
#   disabled  No-op. Use this if you don't want any emails at all.
EMAIL_BACKEND=console
EMAIL_FROM=bugtracker@localhost

# Only required when EMAIL_BACKEND=smtp.
# Examples:
#   Gmail:           SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USE_TLS=true
#                    (Use an App Password — not your account password.)
#   Office 365:      SMTP_HOST=smtp.office365.com  SMTP_PORT=587  SMTP_USE_TLS=true
#   SendGrid:        SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USERNAME=apikey
#   Postmark:        SMTP_HOST=smtp.postmarkapp.com  SMTP_PORT=587
#   Mailtrap (test): SMTP_HOST=sandbox.smtp.mailtrap.io  SMTP_PORT=2525  SMTP_USE_TLS=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=10
